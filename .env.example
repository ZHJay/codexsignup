# Outlook Email Plus（邮箱池中台 / 管理面板）
# 本机直跑：http://127.0.0.1:5001 或公网 https://outlook.api4kimi8.org
# 小站同机 Docker：http://outlook-email-plus:5000
OEP_BASE_URL=https://outlook.api4kimi8.org
OEP_API_KEY=your-oep-external-api-key
# 池筛选：outlook / imap / custom（禁止 cloudflare_temp_mail）
OEP_PROVIDER=outlook
OEP_PROJECT_KEY=codex_register
OEP_CALLER_ID=codex_register

# 兼容旧变量名（可选；优先读 OEP_*）
# MAIL_BASE_URL=
# MAIL_API_KEY=

# OEP 管理端密码（用于注册结果后移动分组；不是 X-API-Key）
# 在 OEP 管理面板登录密码 / 服务器 CREDENTIALS.txt 的 LOGIN_PASSWORD
OEP_ADMIN_PASSWORD=your-oep-admin-login-password
# OEP_GROUP_SUCCESS=GPT success
OEP_GROUP_FAILURE=Garbage
# 仅从此分组领取邮箱（默认「默认分组」）
OEP_CLAIM_GROUP=默认分组
# OEP_CLAIM_GROUP_RETRIES=30

# Tiger SMS（手机验证，仅 v2：getNumberV2 / getStatusV2 / setStatusV2）
# 文档：https://tiger-sms.com/cn/api#m-getNumberV2
TIGER_SMS_API_KEY=your-tiger-sms-api-key
TIGER_SMS_SERVICE=dr
TIGER_SMS_COUNTRY=1001
# 可选：上限价；不填则用 getPricesV2.saleAveragePrice
# TIGER_SMS_MAX_PRICE=0.05
# TIGER_SMS_POLL_SECONDS=120
# TIGER_SMS_NUMBER_RETRIES=3
# TIGER_SMS_BASE_URL=https://api.tiger-sms.com/stubs/handler_api.php

# 方案 C：真浏览器过 Cloudflare
# USE_BROWSER=1
# BROWSER_HEADLESS=0
# BROWSER_CHANNEL=chrome
# BROWSER_CF_TIMEOUT_MS=120000
# IMPERSONATE=chrome146
